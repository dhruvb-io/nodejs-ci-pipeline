pipeline {
    agent {
        docker {
            image 'node:16'   // Use official Node.js image
            args '-p 3000:3000' // Optional: expose ports if needed
        }
    }

    stages {
        stage('Install') {
            steps {
                sh 'npm install'
            }
        }

        stage('Test') {
            steps {
                sh 'npm test'
            }
        }

        stage('Start') {
            steps {
                sh 'npm run start'
            }
        }
    }

    post {
        success {
            echo 'Build Successful'
        }
        failure {
            echo 'Build Failed'
        }
    }
}